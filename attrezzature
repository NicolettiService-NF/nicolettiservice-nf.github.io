<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    :root {
      --blue:#0b63ce;
      --blue-light:#4aa3ff;
      --dark:#071d3a;
      --text:#102033;
      --muted:#64748b;
      --bg:#f4f7fb;
      --white:#ffffff;
    }

    * { box-sizing:border-box; }

    body {
      margin:0;
      font-family:Arial, sans-serif;
      background:var(--bg);
      color:var(--text);
    }

    .navbar {
      background:rgba(255,255,255,.96);
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:14px 42px;
      box-shadow:0 6px 20px rgba(0,0,0,.08);ndex
      position:sticky;
      top:0;
      z-index:50;
    }

    .brand {
      display:flex;
      align-items:center;
      gap:16px;
    }

    .logo {
      color:var(--blue);
      font-size:24px;
      font-weight:900;
      line-height:.9;
    }

    .logo span {
      display:block;
      font-size:11px;
      letter-spacing:3px;
    }

    .subtitle {
      border-left:1px solid #dbe4ef;
      padding-left:16px;
      color:var(--muted);
      font-size:14px;
    }

    .nav {
      display:flex;
      align-items:center;
      gap:24px;
    }

    .nav a {
      text-decoration:none;
      color:var(--dark);
      font-weight:700;
      font-size:14px;
    }

    .nav .cta {
      background:var(--blue);
      color:white;
      padding:11px 17px;
      border-radius:8px;
    }

    .hero {
      min-height:500px;
      display:flex;
      align-items:center;
      padding:70px 56px;
      color:white;
      background-image:
        linear-gradient(90deg, rgba(7,29,58,.92) 0%, rgba(7,29,58,.78) 40%, rgba(7,29,58,.20) 75%),
        url("images/GElati.png");
      background-size:cover;
      background-position:center right;
    }

    .hero-content {
      max-width:760px;
    }

    .eyebrow {
      color:var(--blue-light);
      font-size:16px;
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.8px;
      margin-bottom:16px;
    }

    .hero h1 {
      margin:0;
      font-size:54px;
      line-height:1.04;
      text-transform:uppercase;
    }

    .hero h1 span {
      color:var(--blue-light);
    }

    .hero p {
      max-width:650px;
      margin:24px 0 32px;
      font-size:20px;
      line-height:1.55;
    }

    .buttons {
      display:flex;
      gap:14px;
      flex-wrap:wrap;
    }

    .btn {
      display:inline-block;
      padding:14px 22px;
      border-radius:9px;
      text-decoration:none;
      font-weight:800;
      font-size:14px;
    }

    .btn.primary {
      background:var(--blue);
      color:white;
    }

    .btn.secondary {
      color:white;
      border:1px solid rgba(255,255,255,.75);
      background:rgba(255,255,255,.10);
    }

    .section {
      max-width:1180px;
      margin:65px auto;
      padding:0 24px;
    }

    .section-title {
      text-align:center;
      margin-bottom:34px;
    }

    .section-title .small {
      color:var(--blue);
      font-weight:900;
      text-transform:uppercase;
      margin-bottom:8px;
    }

    .section-title h2 {
      margin:0;
      font-size:34px;
      color:var(--dark);
    }

    .row-title {
      margin:38px 0 18px;
      font-size:20px;
      color:var(--dark);
      text-transform:uppercase;
      letter-spacing:.4px;
    }

    .service-row {
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:18px;
    }

    .service-card {
      background:white;
      border-radius:18px;
      overflow:hidden;
      box-shadow:0 12px 28px rgba(13,52,92,.11);
      border:1px solid #e7eef8;
      min-height:285px;
    }

    .service-card img {
      width:100%;
      height:135px;
      object-fit:cover;
      display:block;
    }

    .service-card .card-content {
      padding:18px;
    }

    .service-card h3 {
      margin:0 0 9px;
      color:var(--dark);
      text-transform:uppercase;
      font-size:16px;
    }

    .service-card p {
      margin:0;
      color:var(--muted);
      line-height:1.5;
      font-size:13px;
    }

    .equipment-card {
      background:white;
      border-radius:18px;
      padding:24px 18px;
      min-height:210px;
      box-shadow:0 12px 28px rgba(13,52,92,.09);
      border:1px solid #e7eef8;
      text-align:center;
    }

    .line-icon {
      width:62px;
      height:62px;
      margin:0 auto 16px;
      border-radius:18px;
      background:#eef5ff;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .line-icon svg {
      width:34px;
      height:34px;
      stroke:var(--blue);
      stroke-width:2;
      fill:none;
      stroke-linecap:round;
      stroke-linejoin:round;
    }

    .equipment-card h3 {
      margin:0 0 10px;
      color:var(--dark);
      text-transform:uppercase;
      font-size:15px;
      line-height:1.3;
    }

    .equipment-card p {
      margin:0;
      color:var(--muted);
      font-size:13px;
      line-height:1.5;
    }

    .process {
      background:white;
      padding:55px 24px;
    }

    .process-grid {
      max-width:1180px;
      margin:auto;
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:20px;
    }

    .process-box {
      background:#f7faff;
      border:1px solid #e1eaf5;
      border-radius:18px;
      padding:24px;
    }

    .process-box .num {
      width:42px;
      height:42px;
      border-radius:12px;
      background:var(--blue);
      color:white;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:900;
      margin-bottom:14px;
    }

    .process-box strong {
      display:block;
      color:var(--dark);
      font-size:18px;
      margin-bottom:8px;
    }

    .process-box p {
      margin:0;
      color:var(--muted);
      font-size:14px;
      line-height:1.5;
    }

    .info-band {
      background:var(--dark);
      color:white;
      padding:45px 24px;
    }

    .info-grid {
      max-width:1180px;
      margin:auto;
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:24px;
    }

    .info-box {
      border-left:1px solid rgba(255,255,255,.18);
      padding-left:20px;
    }

    .info-box strong {
      display:block;
      color:var(--blue-light);
      font-size:18px;
      margin-bottom:8px;
    }

    .info-box p {
      margin:0;
      color:#d5e2f0;
      font-size:14px;
      line-height:1.5;
    }

    footer {
      background:#06162c;
      color:white;
      padding:38px 48px 18px;
    }

    .footer-container {
      max-width:1180px;
      margin:auto;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:40px;
    }

    footer h3 {
      margin:0 0 12px;
      color:var(--blue-light);
    }

    footer p {
      margin:5px 0;
      color:#d5e2f0;
      font-size:14px;
    }

    .footer-bottom {
      max-width:1180px;
      margin:28px auto 0;
      padding-top:15px;
      border-top:1px solid rgba(255,255,255,.12);
      color:#9fb2c8;
      font-size:13px;
      text-align:right;
    }

    @media(max-width:900px) {
      .service-row,
      .process-grid,
      .info-grid,
      .footer-container {
        grid-template-columns:repeat(2,1fr);
      }
    }

    @media(max-width:768px) {
      .navbar {
        padding:14px 18px;
        align-items:flex-start;
        flex-direction:column;
        gap:12px;
      }

      .subtitle {
        display:none;
      }

      .nav {
        width:100%;
        display:grid;
        grid-template-columns:repeat(2,1fr);
        gap:10px;
      }

      .nav a {
        background:#eef5ff;
        padding:11px;
        border-radius:8px;
        text-align:center;
        font-size:13px;
      }

      .nav .cta {
        background:var(--blue);
        color:white;
      }

      .hero {
        min-height:500px;
        padding:42px 22px;
        background-image:
          linear-gradient(180deg, rgba(7,29,58,.94) 0%, rgba(7,29,58,.78) 55%, rgba(7,29,58,.35) 100%),
          url("images/GElati.png");
        background-position:center;
      }

      .hero h1 {
        font-size:35px;
      }

      .hero p {
        font-size:16px;
      }

      .buttons {
        flex-direction:column;
      }

      .btn {
        width:100%;
        text-align:center;
      }

      .service-row,
      .process-grid,
      .info-grid,
      .footer-container {
        grid-template-columns:1fr;
      }

      .service-card {
        min-height:auto;
      }

      .service-card img {
        height:170px;
      }

      .section {
        margin:45px auto;
      }

      .section-title h2 {
        font-size:28px;
      }

      footer {
        padding:34px 22px 18px;
      }

      .footer-bottom {
        text-align:left;
      }
    }
  </style>
</head>

