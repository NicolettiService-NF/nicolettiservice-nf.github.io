<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    :root {
      --blue:#0b63ce;
      --blue-light:#4aa3ff;
      --dark:#071d3a;
      --text:#102033;
      --muted:#64748b;
      --bg:#f4f7fb;
      --white:#ffffff;
    }

    * { box-sizing:border-box; }

    body {
      margin:0;
      font-family:Arial, sans-serif;
      background:var(--bg);
      color:var(--text);
    }

    .navbar {
      background:white;
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:14px 42px;
      box-shadow:0 6px 20px rgba(0,0,0,.08);
      position:sticky;
      top:0;
      z-index:50;
    }

    .brand {
      display:flex;
      align-items:center;
      gap:16px;
    }

    .logo {
      color:var(--blue);
      font-size:24px;
      font-weight:900;
      line-height:.9;
    }

    .logo span {
      display:block;
      font-size:11px;
      letter-spacing:3px;
    }

    .subtitle {
      border-left:1px solid #dbe4ef;
      padding-left:16px;
      color:var(--muted);
      font-size:14px;
    }

    .nav {
      display:flex;
      align-items:center;
      gap:24px;
    }

    .nav a {
      text-decoration:none;
      color:var(--dark);
      font-weight:700;
      font-size:14px;
    }

    .nav .cta {
      background:var(--blue);
      color:white;
      padding:11px 17px;
      border-radius:8px;
    }

    .hero {
      background:#003f91;
      color:white;
      padding:70px 56px;
      display:grid;
      grid-template-columns:1fr 1.2fr;
      gap:50px;
      align-items:center;
    }

    .hero h1 {
      margin:0;
      font-size:52px;
      line-height:1.08;
    }

    .hero h1 span {
      color:#7cc2ff;
    }

    .eyebrow {
      color:#7cc2ff;
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.8px;
      margin-bottom:14px;
    }

    .hero p {
      font-size:20px;
      line-height:1.55;
      margin:22px 0 28px;
    }

    .hero img {
      width:100%;
      border-radius:20px;
      box-shadow:0 20px 45px rgba(0,0,0,.25);
    }

    .btn {
      display:inline-block;
      background:#1685f2;
      color:white;
      text-decoration:none;
      padding:14px 22px;
      border-radius:9px;
      font-weight:800;
    }

    .section {
      max-width:1180px;
      margin:60px auto;
      padding:0 24px;
    }

    .section-title {
      text-align:center;
      margin-bottom:34px;
    }

    .section-title .small {
      color:var(--blue);
      font-weight:900;
      text-transform:uppercase;
      margin-bottom:8px;
    }

    .section-title h2 {
      margin:0;
      font-size:34px;
      color:var(--dark);
    }

    .service-grid {
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:24px;
    }

    .service-box {
      background:white;
      border-radius:20px;
      padding:30px 24px;
      text-align:center;
      box-shadow:0 14px 32px rgba(13,52,92,.11);
      border:1px solid #e7eef8;
    }

    .icon {
      width:68px;
      height:68px;
      margin:0 auto 18px;
      border-radius:50%;
      background:#eaf4ff;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .icon svg {
      width:34px;
      height:34px;
      stroke:var(--blue);
      stroke-width:2;
      fill:none;
      stroke-linecap:round;
      stroke-linejoin:round;
    }

    .service-box h3 {
      margin:0 0 12px;
      font-size:18px;
      color:var(--dark);
    }

    .service-box p {
      margin:0;
      font-size:14px;
      color:var(--muted);
      line-height:1.55;
    }

    .two-col {
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:34px;
      align-items:center;
    }

    .text-block {
      background:white;
      border-radius:22px;
      padding:34px;
      box-shadow:0 14px 32px rgba(13,52,92,.10);
    }

    .text-block h2 {
      margin:0 0 18px;
      font-size:32px;
      color:var(--dark);
    }

    .text-block p {
      color:var(--muted);
      font-size:16px;
      line-height:1.65;
    }

    .text-block ul {
      margin:20px 0 0;
      padding:0;
      list-style:none;
    }

    .text-block li {
      margin:12px 0;
      color:var(--text);
      font-weight:600;
    }

    .text-block li::before {
      content:"✓";
      color:var(--blue);
      font-weight:900;
      margin-right:10px;
    }

    .two-col img {
      width:100%;
      border-radius:22px;
      box-shadow:0 14px 32px rgba(13,52,92,.14);
    }

    .info-band {
      background:var(--dark);
      color:white;
      padding:42px 24px;
    }

    .info-grid {
      max-width:1180px;
      margin:auto;
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:24px;
    }

    .info-box {
      border-left:1px solid rgba(255,255,255,.18);
      padding-left:20px;
    }

    .info-box strong {
      display:block;
      color:var(--blue-light);
      font-size:18px;
      margin-bottom:8px;
    }

    .info-box p {
      margin:0;
      color:#d5e2f0;
      font-size:14px;
      line-height:1.5;
    }

    footer {
      background:#06162c;
      color:white;
      padding:38px 48px 18px;
    }

    .footer-container {
      max-width:1180px;
      margin:auto;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:40px;
    }

    footer h3 {
      margin:0 0 12px;
      color:var(--blue-light);
    }

    footer p {
      margin:5px 0;
      color:#d5e2f0;
      font-size:14px;
    }

    .footer-bottom {
      max-width:1180px;
      margin:28px auto 0;
      padding-top:15px;
      border-top:1px solid rgba(255,255,255,.12);
      color:#9fb2c8;
      font-size:13px;
      text-align:right;
    }

    @media(max-width:768px) {
      .navbar {
        padding:14px 18px;
        flex-direction:column;
        align-items:flex-start;
        gap:12px;
      }

      .subtitle {
        display:none;
      }

      .nav {
        width:100%;
        display:grid;
        grid-template-columns:repeat(2,1fr);
        gap:10px;
      }

      .nav a {
        background:#eef5ff;
        padding:11px;
        border-radius:8px;
        text-align:center;
        font-size:13px;
      }

      .nav .cta {
        background:var(--blue);
        color:white;
      }

      .hero {
        grid-template-columns:1fr;
        padding:42px 22px;
      }

      .hero h1 {
        font-size:36px;
      }

      .hero p {
        font-size:16px;
      }

      .service-grid,
      .two-col,
      .info-grid,
      .footer-container {
        grid-template-columns:1fr;
      }

      .section {
        margin:45px auto;
      }

      .section-title h2 {
        font-size:28px;
      }

      footer {
        padding:34px 22px 18px;
      }

      .footer-bottom {
        text-align:left;
      }
    }
  </style>
</head>

